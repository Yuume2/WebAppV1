{
  "name": "webapp-v1",
  "version": "0.1.0",
  "private": true,
  "description": "AI Workspace V1 — monorepo root",
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "api:smoke:ai": "pnpm --filter @webapp/api smoke:ai",
    "api:smoke:ai:stream": "pnpm --filter @webapp/api smoke:ai:stream",
    "format": "prettier --write \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "format:check": "prettier --check \"**/*.{ts,tsx,js,json,md,css,yml,yaml}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "issues:dry-run": "node tools/create-github-issues.mjs --dry-run",
    "issues:create": "node tools/create-github-issues.mjs --yes",
    "project:fields:dry-run": "node tools/update-project-fields.mjs --dry-run",
    "project:fields:apply": "node tools/update-project-fields.mjs --yes",
    "issues:delta:dry-run": "node tools/apply-issue-delta.mjs --dry-run",
    "issues:delta:apply": "node tools/apply-issue-delta.mjs --yes",
    "project:status": "node tools/issue-status.mjs",
    "project:status:test": "node --test tools/issue-status.test.mjs",
    "project:status:in-progress": "node tools/issue-status.mjs --status \"In Progress\"",
    "project:status:review": "node tools/issue-status.mjs --status Review",
    "project:status:blocked": "node tools/issue-status.mjs --status Blocked",
    "project:status:done": "node tools/issue-status.mjs --status Done",
    "task:next": "node tools/next-task.mjs",
    "task:stale": "node tools/stale-check.mjs",
    "task:score": "node tools/task-score.mjs",
    "task:queue": "node tools/task-score.mjs --queue",
    "task:deps": "node tools/task-deps.mjs",
    "task:meta": "node tools/task-meta.mjs",
    "task:meta:check": "node tools/task-meta.mjs --json",
    "task:meta:backfill": "node tools/task-meta-backfill.mjs",
    "task:doctor": "node tools/task-doctor.mjs",
    "task:deps:test": "node --test tools/task-deps.test.mjs"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.6.3",
    "prettier": "^3.4.2"
  }
}
