DATABASE_URL=
NEXT_PUBLIC_APP_URL=
NEXT_PUBLIC_API_URL=
API_PORT=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=

# ── Observability ─────────────────────────────────────────────────────────────
# Error tracking (Sentry). Leave empty to disable — integration is a safe no-op.
# Server DSN (apps/api). See docs/technical/adr/0002-sentry-for-error-tracking.md
SENTRY_DSN_API=
# Browser DSN (apps/web). Safe to expose to the client. Prepared, not wired yet.
NEXT_PUBLIC_SENTRY_DSN=
# Optional — overrides the environment tag reported to Sentry. Defaults to NODE_ENV.
# SENTRY_ENVIRONMENT=
# Optional — release identifier reported to Sentry (e.g. a git SHA).
# SENTRY_RELEASE=

# ── Product analytics (prepared — not wired yet) ──────────────────────────────
# PostHog. Leave empty to disable. See docs/technical/adr/0003-posthog-deferred.md
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://eu.i.posthog.com
