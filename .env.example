# PostgreSQL connection string used by the API (Drizzle ORM)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webapp_dev
NEXT_PUBLIC_APP_URL=
# Frontend → backend URL (Next.js reads this at build and runtime)
NEXT_PUBLIC_API_URL=http://localhost:4000
API_PORT=
# Max JSON request body in bytes (default: 102400 = 100 KB)
API_MAX_BODY_BYTES=
# Enable /v1/dev/reset and /v1/dev/seed endpoints (default: true unless NODE_ENV=production)
ENABLE_DEV_ENDPOINTS=
# Allowed CORS origin. Must be an explicit URL (not '*') to support cookie-based auth.
# Set to your frontend dev URL so that credentialed requests from the browser work.
CORS_ORIGIN=http://localhost:3000
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
PERPLEXITY_API_KEY=
