# ── Backend API ───────────────────────────────────────────────────────────────

# Port the API server listens on (default: 4000)
API_PORT=4000

# Node environment: development | production | test (default: development)
NODE_ENV=development

# Service version reported by /health (default: 0.1.0). Optional.
# API_VERSION=0.1.0

# PostgreSQL connection string (Drizzle ORM).
# Leave unset to run in in-memory mode (no auth, no persistent storage).
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/webapp_dev

# 32-byte AES-256-GCM key used to encrypt stored provider API keys.
# Required when DATABASE_URL is set. Generate with:
#   node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
PROVIDER_ENCRYPTION_KEY=

# Allowed CORS origin for the API.
# Must be an explicit URL (not '*') when DATABASE_URL is set — cookie-based
# session auth will not work in a browser with a wildcard origin.
CORS_ORIGIN=http://localhost:3000

# Maximum number of prior messages included in OpenAI context (default: 20)
OPENAI_MAX_CONTEXT_MESSAGES=20

# Maximum JSON request body size in bytes (default: 102400 = 100 KB)
API_MAX_BODY_BYTES=102400

# Set to 'true' to enable /v1/dev/reset and /v1/dev/seed endpoints.
# Defaults to true unless NODE_ENV=production.
ENABLE_DEV_ENDPOINTS=true

# ── Frontend (Next.js) ────────────────────────────────────────────────────────

# Public API URL read by the Next.js frontend
NEXT_PUBLIC_API_URL=http://localhost:4000

# Public app URL (used for redirects etc.)
NEXT_PUBLIC_APP_URL=http://localhost:3000
