# Local env template for scripts/notion/sync-questions.mjs
# Copy to scripts/notion/.env.questions.local and fill in values.
# NEVER commit the .local file.

NOTION_TOKEN=secret_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
NOTION_QUESTIONS_DATABASE_ID=00000000000000000000000000000000

# GITHUB_TOKEN is read automatically from `gh auth token` when running locally.
# In GitHub Actions, the workflow injects it from secrets.GITHUB_TOKEN.
GITHUB_REPOSITORY=Yuume2/WebAppV1

# Optional
# DRY_RUN=1
# ONLY_GH_TO_NOTION=1
# ONLY_NOTION_TO_GH=1
